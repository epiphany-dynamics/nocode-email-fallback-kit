# Resend API key. Create one at https://resend.com/api-keys
# Never commit the real value; this file is a template only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sending address. Must be on a domain you have verified in Resend
# (Resend > Domains) with SPF + DKIM records published. Using an
# unverified domain, or Resend's own shared test domain, in production
# reintroduces the exact deliverability problem this kit exists to fix.
FROM_EMAIL="Website Notifications <notifications@yourdomain.com>"

# Where the business wants form submissions delivered. Can be a
# comma-free single address; for multiple recipients, send a
# comma-separated list and update api/webhook.js to split it into an
# array before passing to sendTransactionalEmail.
NOTIFY_EMAIL=owner@yourdomain.com

# Optional. Shown in the notification email header and log lines to
# distinguish this integration if you run more than one form/site through
# the same fallback pipeline.
SOURCE_LABEL="Website contact form"

# Optional but recommended. Set this to a random string and configure your
# no-code platform's webhook action to send it as a header
# (X-Webhook-Secret) or query param (?secret=...), so the endpoint rejects
# traffic that isn't actually coming from your form.
WEBHOOK_SECRET=

# Local dev server port (dev-server.js only; unused when deployed).
PORT=3000
